# 이 파일은 "어떤 키가 필요한지" 보여주는 템플릿입니다. (git에 커밋되는 파일)
# ⚠️ 실제 키는 여기 넣지 마세요. 복사해서 .env.local 에 넣으세요.
#   cp .env.local.example .env.local
#
# OpenAI API 키 — https://platform.openai.com/api-keys 에서 발급
# (ChatGPT 구독과는 별개. API는 사용한 만큼 과금됩니다.)
OPENAI_API_KEY=sk-여기에-실제-키-입력

# (선택) 사용할 생성 모델. 비워두면 코드 기본값(gpt-4o-mini)을 씁니다.
# OPENAI_MODEL=gpt-4o-mini

# (선택) 임베딩 제공자: openai(기본) | local(학습용 로컬 모델). 비워두면 openai.
# EMBEDDING_PROVIDER=openai
# OPENAI_EMBED_MODEL=text-embedding-3-small

# (선택) 검색 최소 유사도 컷오프. 비워두면 제공자별 기본값. `npm run eval`로 점수 보고 조정.
# RAG_MIN_SCORE=0.45
